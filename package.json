{
  "name": "delete-stale-cloudflare-pages-deployments",
  "version": "1.2.0",
  "description": "",
  "repository": "https://github.com/SukkaW/delete-stale-cloudflare-pages-deployments",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.mjs",
  "types": "./dist/cjs/index.d.cts",
  "bin": "./dist/bin/index.cjs",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/es/index.d.mts",
        "default": "./dist/es/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bunchee --clean --minify --no-sourcemap",
    "lint": "eslint --format=sukka",
    "node": "node -r @swc-node/register",
    "prerelease": "pnpm run build && pnpm run lint",
    "release": "bumpp -r --all --commit \"release: %s\" --tag \"%s\""
  },
  "keywords": [],
  "author": "Sukka <https://skk.moe>",
  "license": "MIT",
  "dependencies": {
    "@henrygd/queue": "^1.2.0",
    "cloudflare": "^5.2.0",
    "consola": "^3.4.2",
    "foxts": "^5.4.0"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^13.1.0",
    "@eslint-sukka/node": "^8.9.1",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.21",
    "@types/node": "^22.19.17",
    "bumpp": "^10.4.1",
    "bunchee": "^6.9.4",
    "commander": "^13.1.0",
    "date-fns": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-config-sukka": "^8.9.1",
    "eslint-formatter-sukka": "^8.9.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "oxc-resolver"
    ],
    "overrides": {
      "eslint>chalk": "npm:picocolors@1.1.1"
    }
  }
}
